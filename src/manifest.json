{
  "manifest_version": 3,
  "name": "AI Prompt Reframer",
  "version": "2.0.0",
  "description": "Reframing stream-of-consciousness AI prompts into professional formats",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {}
}
